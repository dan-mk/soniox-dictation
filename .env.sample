# Obrigatorio
SONIOX_API_KEY=

# Opcionais
SONIOX_LANGUAGE_HINTS=pt,en
SONIOX_MODEL=stt-rt-v4
# Modelo do fallback assincrono quando a conexao em tempo real cai.
# Por padrao e derivado do SONIOX_MODEL (stt-rt-v4 -> stt-async-v4).
# SONIOX_ASYNC_MODEL=stt-async-v4

# Use apenas se o ydotool nao estiver no PATH ou se o daemon usar outro socket.
# SONIOX_YDOTOOL_COMMAND=/usr/local/bin/ydotool-v1.0.4
# SONIOX_YDOTOOL_SOCKET=/tmp/.ydotool_socket
